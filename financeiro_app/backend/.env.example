DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DB_NAME
CORS_ORIGINS=https://SEU-PROJETO.vercel.app,http://localhost:3000
AUTOMATION_WORKSPACE=/opt/render/project/src/financeiro_app
RECOVER_INTERRUPTED_RUNS=true
FRONTEND_URL=http://localhost:3000
# Apenas desenvolvimento: devolve o link de reset na resposta de /auth/forgot-password
EXPOSE_PASSWORD_RESET_LINK=false

# Notificação de novo cadastro pendente (opcional)
SMTP_HOST=smtp.seu-provedor.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@suaempresa.com
SMTP_USE_TLS=true
ADMIN_NOTIFY_EMAILS=admin@suaempresa.com,gestor@suaempresa.com
