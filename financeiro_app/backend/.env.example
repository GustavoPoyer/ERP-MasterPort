DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DB_NAME
CORS_ORIGINS=https://SEU-PROJETO.vercel.app,http://localhost:3000
AUTOMATION_WORKSPACE=/opt/render/project/src/financeiro_app
RECOVER_INTERRUPTED_RUNS=true
# URL pública do app (Vercel). Em produção, evite localhost — links inválidos no e-mail caem em spam.
FRONTEND_URL=https://SEU-PROJETO.vercel.app
# Apenas desenvolvimento: devolve o link de reset na resposta de /auth/forgot-password
EXPOSE_PASSWORD_RESET_LINK=false

# Notificação por e-mail (cadastros pendentes e mudanças de status na Fila de Automações)
SMTP_HOST=smtp.seu-provedor.com
SMTP_PORT=587
SMTP_USER=kivogo.dev@gmail.com
SMTP_PASSWORD=
SMTP_FROM=kivogo.dev@gmail.com
SMTP_FROM_NAME=KIVO Notificações
# Opcional; padrão: mesmo endereço de SMTP_FROM
SMTP_REPLY_TO=
SMTP_USE_TLS=true
# Destinatários admin (separados por vírgula) — recebem alertas da fila e cadastros
ADMIN_NOTIFY_EMAILS=admin@suaempresa.com,gestor@suaempresa.com

# Integração SigraWeb — Kanban do setor Pedro
SIGRA_API_BASE_URL=https://api.sigraweb.com
SIGRA_APP_BASE_URL=https://app.sigraweb.com
SIGRA_EMAIL=
SIGRA_PASSWORD=
# Opcional: fixa a empresa (senão usa a primeira do login)
SIGRA_EMPRESA_ID=
SIGRA_KANBAN_PAGE_LIMIT=1000
